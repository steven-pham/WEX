# NOTE: POSTGRES_PASSWORD here must match the password in the connection string
# below AND in appsettings.Development.json (the host-run API does NOT read this
# file — only the Postgres container does). Keep all three in sync.
POSTGRES_USER=wex
POSTGRES_PASSWORD=wex_dev_password
POSTGRES_DB=wexcards

# .NET configuration overrides (double-underscore = colon separator)
ConnectionStrings__Default=Host=localhost;Port=5432;Database=wexcards;Username=wex;Password=wex_dev_password
TreasuryApi__BaseUrl=https://api.fiscaldata.treasury.gov
